# Environment variables required by the server runtime + docker-compose.yml.
#
# Local development:
#   Copy this file to .env, fill in real values, then `npm run dev`.
#
# Hostinger deploy (Docker Manager → Install from GitHub URL):
#   Hostinger reads this file to pre-populate the project's Environment panel.
#   Fill in real values in that panel; Hostinger writes them to .env on deploy.
#
# This file is committed as documentation only — NEVER put real secrets here.

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Traefik routing (read at compose load time, not by the app) ──────────────
# Public hostname for the API. Must have an A record pointing at the VPS.
# Tip: for a first deploy you can use stemfra-server.<your-vps>.hstgr.cloud
# (covered by Hostinger's wildcard cert), then switch to api.stemfra.com once
# DNS is set up. Just edit this var and redeploy.
# API_HOST=api.stemfra.com
API_HOST=stemfra-server.srv1555257.hstgr.cloud

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Read by index.js. index.js also hardcodes the production frontends
# (stemfra.com, www.stemfra.com, crm.stemfra.com), so this var is mostly for
# the local dev origin.
CLIENT_URL=http://localhost:5173

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Use the new sb_secret_... key (server-side; bypasses RLS).
# Project Settings → API → "Secret keys" in the Supabase dashboard.
SUPABASE_URL=https://acxepovfklgthxmteqxr.supabase.co
SUPABASE_SECRET_KEY=

# ─── Email (Gmail SMTP via Nodemailer) ────────────────────────────────────────
# Uses an App Password — NOT your Google account password.
# Generate at: https://myaccount.google.com/apppasswords
#
# Test outbound first on the VPS: `nc -vz smtp.gmail.com 587` from Terminal.
# If 587 is blocked, switch to a provider like Resend or Postmark.
GMAIL_USER=support@stemfra.com
GMAIL_APP_PASSWORD=

# Where contact-form notifications are delivered to.
NOTIFY_EMAIL=support@stemfra.com

# ─── Branding (optional — has a fallback in the templates) ───────────────────
LOGO_URL=https://stemfra.com/stemfra_logo.png

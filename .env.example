# Environment variables required by the server runtime + docker-compose.yml.
#
# Local development:
#   Copy this file to .env, fill in real values, then `npm run dev`.
#
# Hostinger deploy (Docker Manager → Install from GitHub URL):
#   Hostinger reads this file to pre-populate the project's Environment panel.
#   Fill in real values in that panel; Hostinger writes them to .env on deploy.
#
# This file is committed as documentation only — NEVER put real secrets here.

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ─── Traefik routing (read at compose load time, not by the app) ──────────────
# Public hostname for the API. Must have an A record pointing at the VPS.
# Tip: for a first deploy you can use stemfra-server.<your-vps>.hstgr.cloud
# (covered by Hostinger's wildcard cert), then switch to api.stemfra.com once
# DNS is set up. Just edit this var and redeploy.
# API_HOST=api.stemfra.com
API_HOST=stemfra-server.srv1555257.hstgr.cloud

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Read by index.js. index.js also hardcodes the production frontends
# (stemfra.com, www.stemfra.com, crm.stemfra.com), so this var is mostly for
# the local dev origin.
CLIENT_URL=http://localhost:5173

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Use the new sb_secret_... key (server-side; bypasses RLS).
# Project Settings → API → "Secret keys" in the Supabase dashboard.
SUPABASE_URL=https://acxepovfklgthxmteqxr.supabase.co
SUPABASE_SECRET_KEY=

# ─── Email (Gmail SMTP via Nodemailer) ────────────────────────────────────────
# Uses an App Password — NOT your Google account password.
# Generate at: https://myaccount.google.com/apppasswords
#
# Test outbound first on the VPS: `nc -vz smtp.gmail.com 587` from Terminal.
# If 587 is blocked, switch to a provider like Resend or Postmark.
GMAIL_USER=support@stemfra.com
GMAIL_APP_PASSWORD=

# Where contact-form notifications are delivered to.
NOTIFY_EMAIL=support@stemfra.com

# ─── Branding (optional — has a fallback in the templates) ───────────────────
LOGO_URL=https://stemfra.com/stemfra_logo.png

# ─── Twilio (SMS + Voice) ─────────────────────────────────────────────────────
# Used by routes/twilio.js. Webhook signature validation requires AUTH_TOKEN.
# The Voice SDK token endpoint additionally needs the API Key + TwiML App SID.
#
# Where to find these:
#   Account SID / Auth Token → Twilio Console → Account Info
#   API Key SID + Secret    → Console → Account → API keys & tokens → Create
#   TwiML App SID           → Console → Voice → TwiML Apps → create one
#                             pointing its Voice URL at /api/twilio/voice
#
# PUBLIC_BASE_URL must be the externally reachable HTTPS base used by Twilio
# webhooks AND used to sign the request URL on our side, e.g. https://api.stemfra.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_PHONE_NUMBER=
TWILIO_TWIML_APP_SID=
PUBLIC_BASE_URL=

# ─── Lead-Gen (n8n bridge) ───────────────────────────────────────────────────
# Used by routes/leadgen.js. The server fires these webhooks against the
# public n8n host — loopback (127.0.0.1) doesn't work because stemfra-server
# and n8n run in separate Docker containers, so 127.0.0.1 from inside the
# stemfra-server container resolves to the container itself, not the VPS.
# We use the n8n public hostname instead and gate authenticity with the
# x-leadgen-secret shared secret below (verified inside the n8n workflow).
#
# Use the PRODUCTION webhook path (/webhook/...), NOT the test path
# (/webhook-test/...). The workflow must be Active in n8n for the production
# path to respond. The trailing segment must match the Webhook Trigger node's
# `path` attribute in the n8n workflow.
#
# N8N_LEADGEN_WARM_URL is for the Warm system (Reddit/Yelp). If unset, the
# server returns 503 for system='warm' requests; once the workflow exists,
# populate this with its production webhook URL.
#
# N8N_WEBHOOK_SECRET is the shared secret. If set, the server sends it as
# the x-leadgen-secret header; the n8n workflow MUST verify it to reject
# anything that didn't come from this server (since the n8n endpoint is
# now publicly reachable).
N8N_LEADGEN_COLD_URL=https://n8n.srv1555257.hstgr.cloud/webhook/leadgen-cold
N8N_LEADGEN_WARM_URL=https://n8n.srv1555257.hstgr.cloud/webhook/leadgen-warm
N8N_WEBHOOK_SECRET=

# Speed-to-Lead — public n8n webhook URL (same n8n instance as lead-gen).
# Leave blank until the workflow is built + activated; the trigger logs the
# arrival and flips status either way, and the escalation scan is the backstop.
N8N_SPEED_TO_LEAD_URL=

# Stacy (CMS copilot, Agent 5) — public n8n webhook URL for the "Stacy" workflow.
# The server sends the same N8N_WEBHOOK_SECRET as the `x-leadgen-secret` header,
# so enabling Header Auth on the webhook requires this secret to match.
# STACY_MODEL is the per-conversation default the n8n provider-switch reads (gpt-4o).
STACY_N8N_URL=https://n8n.srv1555257.hstgr.cloud/webhook/stacy
STACY_MODEL=gpt-4o

# Front Desk (Agent 2) — the customer-facing chat widget on a client's template
# site. PUBLIC endpoint (/api/site-chat); reuses the same N8N_WEBHOOK_SECRET as the
# x-leadgen-secret header. FRONTDESK_N8N_URL is the public n8n webhook for the
# "Front Desk" workflow; FRONTDESK_MODEL is the per-conversation default (gpt-4o).
FRONTDESK_N8N_URL=https://n8n.srv1555257.hstgr.cloud/webhook/frontdesk
FRONTDESK_MODEL=gpt-4o

# Concierge (Agent 1) — the chat on Stemfra's OWN marketing site (stemfra_client).
# PUBLIC endpoint (/api/concierge); reuses the same N8N_WEBHOOK_SECRET as the
# x-leadgen-secret header. CONCIERGE_N8N_URL is the public n8n webhook for the
# "Concierge" workflow; CONCIERGE_MODEL is the per-conversation default (gpt-4o).
CONCIERGE_N8N_URL=https://n8n.srv1555257.hstgr.cloud/webhook/concierge
CONCIERGE_MODEL=gpt-4o

# ─── Stemfra Voice (Agent 3) — Twilio ConversationRelay ───────────────────────
# The voice brain runs the LLM DIRECTLY in the server (not n8n — too slow for live
# audio), so the server needs its OWN OpenAI key. Reuse the same key that's in the
# n8n OpenAI credential. Without it, voice calls answer with a "can't take the call"
# message but the rest of the server runs fine.
#   • OPENAI_API_KEY     — sk-... (SECRET — set in .env / a GitHub secret, NEVER here)
#   • VOICE_MODEL        — chat model for the voice loop (gpt-4o-mini = fast first-token)
#   • VOICE_PHONE_NUMBER — the Stemfra Voice line in E.164 (outbound "From"; the inbound
#                          number is set on the Twilio webhook, not read from here)
#   • PUBLIC_BASE_URL    — already defined above (Twilio webhooks); the wss relay URL is
#     derived from it (https→wss) + /voice/relay. For LOCAL testing, point a tunnel
#     (ngrok/cloudflared) at :4000 and set PUBLIC_BASE_URL to the tunnel's https URL.
# Twilio: enable the Predictive & Generative AI/ML Features Addendum, then point a
# number's Voice "A Call Comes In" webhook at POST {PUBLIC_BASE_URL}/api/voice/concierge/incoming.
OPENAI_API_KEY=
VOICE_MODEL=gpt-4o-mini
VOICE_PHONE_NUMBER=+16672205540
# LEADGEN_MODEL — model for the CRM lead-gen outreach-refine copilot (the
# back-office drafting side standardizes on GPT; the customer-facing agents stay
# multi-model). Uses the same OPENAI_API_KEY above.
LEADGEN_MODEL=gpt-4o

# ─── Lead-gen outreach send (Gmail, send-as-the-rep) ─────────────────────────
# Sends approved lead-gen drafts from the rep's own @stemfra.com inbox via a
# Google service account with DOMAIN-WIDE DELEGATION (impersonation). One-time
# setup (Google super-admin): create a service account + JSON key; in
# admin.google.com → Security → API controls → Domain-wide Delegation, authorize
# the SA client id for scope gmail.send (+ gmail.readonly for Phase 2 replies).
#   • GOOGLE_SA_CLIENT_EMAIL — the service account email (…@…iam.gserviceaccount.com)
#   • GOOGLE_SA_PRIVATE_KEY  — the SA private key from the JSON (SECRET; keep the
#     literal \n escapes — the server converts them to newlines)
GOOGLE_SA_CLIENT_EMAIL=
GOOGLE_SA_PRIVATE_KEY=
# MARK_EMAIL — the dedicated outreach identity the SA impersonates (send + reply-read).
MARK_EMAIL=mark@stemfra.com

# ─── Cloudinary (image/video uploads — Slice 2c) ──────────────────────────────
# All three required for CMS uploads. config/cloudinary.js warns at boot if any
# are missing; GET /api/cms/site-uploads/healthcheck reports cloudinary_configured.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Stripe (Payments) ────────────────────────────────────────────────────────
# Connect destination charges (System B: a business bills its end-customers) +
# platform billing (System A). Handlers return 503 until STRIPE_SECRET_KEY is set.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Platform margin (basis points) added on top of the estimated Stripe fee on each
# destination charge. 150 = 1.5%. Non-secret; safe to tune.
STRIPE_APPLICATION_FEE_BPS=150
# Estimate of Stripe's OWN processing fee, used to size the application fee so the
# platform nets positive on destination charges (it pays Stripe's fee). Defaults
# match US card pricing (2.9% + 30¢). Non-secret.
STRIPE_PROCESSING_PCT_BPS=290
STRIPE_PROCESSING_FIXED_CENTS=30
# % the platform keeps on each native membership invoice (System B Connect
# subscriptions). Must beat Stripe's effective rate to net positive. Non-secret.
STRIPE_SUBSCRIPTION_APP_FEE_PCT=4.5

# ─── CMS + platform-billing URLs ──────────────────────────────────────────────
# Live CMS (owner dashboard). Return URL after Stripe Connect onboarding + the
# platform-billing return fallback. Local dev = http://localhost:5180.
CMS_URL=https://cms.stemfra.com
# Where Stripe returns a business after paying a Stemfra platform invoice
# (System A). Falls back to CMS_URL when unset.
PLATFORM_BILLING_RETURN_URL=https://cms.stemfra.com

# ─── Staff guard (System A platform billing) ──────────────────────────────────
# Shared secret protecting the staff-only /api/platform-billing/* endpoints until
# proper staff auth ships. Leave UNSET → those endpoints fail closed in
# production (safe). Set it + send header x-stemfra-admin-secret to enable them.
STEMFRA_ADMIN_SECRET=